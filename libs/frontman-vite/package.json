{
	"name": "@frontman-ai/vite",
	"publishConfig": {
		"access": "public"
	},
	"version": "0.4.2",
	"description": "Vite integration for Frontman - AI-powered development tools",
	"license": "Apache-2.0",
	"author": "Frontman AI",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/frontman-ai/frontman.git",
		"directory": "libs/frontman-vite"
	},
	"homepage": "https://frontman.sh",
	"bugs": {
		"url": "https://github.com/frontman-ai/frontman/issues"
	},
	"keywords": [
		"frontman",
		"vite",
		"vite-plugin",
		"ai",
		"react",
		"vue",
		"svelte",
		"browser",
		"visual-editing",
		"developer-tools",
		"frontend",
		"development",
		"middleware"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
