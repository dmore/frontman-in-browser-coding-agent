{
	"name": "@frontman-ai/frontman-protocol",
	"namespace": true,
	"reanalyze": {
		"analysis": ["dce"],
		"suppress": [],
		"unsuppress": [],
		"transitive": false
	},
	"sources": [
		{
			"dir": "src",
			"subdirs": true
		},
		{
			"dir": "scripts",
			"type": "dev"
		}
	],
	"package-specs": [
		{
			"module": "esmodule",
			"in-source": true,
			"suffix": ".res.mjs"
		}
	],
	"ppx-flags": ["sury-ppx/bin"],
	"dependencies": ["@rescript/webapi", "sury"],
	"dev-dependencies": ["@frontman/bindings"]
}
