{
	"name": "@frontman-ai/frontman-client",
	"namespace": true,
	"reanalyze": {
		"analysis": ["dce"],
		"suppress": [],
		"unsuppress": [],
		"transitive": false
	},
	"sources": [
		{
			"dir": "src",
			"subdirs": true
		},
		{
			"dir": "test",
			"subdirs": true,
			"type": "dev"
		}
	],
	"package-specs": [
		{
			"module": "esmodule",
			"in-source": true,
			"suffix": ".res.mjs"
		}
	],
	"ppx-flags": ["sury-ppx/bin"],
	"dependencies": ["@rescript/webapi", "sury", "@frontman/bindings", "@frontman-ai/frontman-protocol", "@frontman/logs"],
	"dev-dependencies": ["rescript-vitest"],
	"jsx": {
		"version": 4
	}
}
