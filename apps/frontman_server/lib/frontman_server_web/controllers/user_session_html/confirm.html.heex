<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="space-y-8">
    <div class="text-center space-y-2">
      <h1 class="text-2xl font-semibold text-white tracking-tight">Welcome back</h1>
      <p class="text-sm text-white/50">{@user.email}</p>
    </div>

    <.form
      :if={!@user.confirmed_at}
      for={@form}
      id="confirmation_form"
      action={~p"/users/log-in?_action=confirmed"}
      phx-mounted={JS.focus_first()}
      class="space-y-3"
    >
      <input type="hidden" name={@form[:token].name} value={@form[:token].value} />
      <button
        type="submit"
        name={@form[:remember_me].name}
        value="true"
        class={[
          "w-full rounded-lg bg-white px-4 py-3",
          "text-sm font-medium text-[#0a0a0a]",
          "transition-all duration-150",
          "hover:bg-white/90 active:scale-[0.98]"
        ]}
      >
        Confirm and stay logged in
      </button>
      <button
        type="submit"
        class={[
          "w-full rounded-lg border border-white/[0.12] bg-white/[0.04]",
          "px-4 py-3 text-sm font-medium text-white/90",
          "transition-all duration-150",
          "hover:bg-white/[0.08] hover:border-white/[0.18] hover:text-white",
          "active:scale-[0.98]"
        ]}
      >
        Confirm and log in only this time
      </button>
    </.form>

    <.form
      :if={@user.confirmed_at}
      for={@form}
      id="login_form"
      action={~p"/users/log-in"}
      phx-mounted={JS.focus_first()}
      class="space-y-3"
    >
      <input type="hidden" name={@form[:token].name} value={@form[:token].value} />
      <%= if @current_scope do %>
        <button
          type="submit"
          class={[
            "w-full rounded-lg bg-white px-4 py-3",
            "text-sm font-medium text-[#0a0a0a]",
            "transition-all duration-150",
            "hover:bg-white/90 active:scale-[0.98]"
          ]}
        >
          Log in
        </button>
      <% else %>
        <button
          type="submit"
          name={@form[:remember_me].name}
          value="true"
          class={[
            "w-full rounded-lg bg-white px-4 py-3",
            "text-sm font-medium text-[#0a0a0a]",
            "transition-all duration-150",
            "hover:bg-white/90 active:scale-[0.98]"
          ]}
        >
          Keep me logged in on this device
        </button>
        <button
          type="submit"
          class={[
            "w-full rounded-lg border border-white/[0.12] bg-white/[0.04]",
            "px-4 py-3 text-sm font-medium text-white/90",
            "transition-all duration-150",
            "hover:bg-white/[0.08] hover:border-white/[0.18] hover:text-white",
            "active:scale-[0.98]"
          ]}
        >
          Log me in only this time
        </button>
      <% end %>
    </.form>

    <p
      :if={!@user.confirmed_at}
      class="text-center text-xs text-white/30 leading-relaxed rounded-lg border border-white/[0.08] bg-white/[0.02] px-4 py-3"
    >
      Tip: If you prefer passwords, you can enable them in the user settings.
    </p>
  </div>
</Layouts.app>
