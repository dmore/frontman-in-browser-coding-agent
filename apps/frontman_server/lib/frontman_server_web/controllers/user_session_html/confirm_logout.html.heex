<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="flex flex-col items-center justify-center space-y-6 py-12">
    <div class="text-center space-y-2">
      <h1 class="text-xl font-semibold text-white tracking-tight">Signing out…</h1>
      <p class="text-sm text-white/50">You will be redirected shortly.</p>
    </div>

    <%!-- CSRF-protected form that auto-submits via app.js (data-auto-submit).
         Without JS the user sees a manual "Sign out" button as fallback.
         This prevents forced-logout via <img src="/users/log-out"> since the GET
         only renders HTML — session destruction requires the DELETE + CSRF token. --%>
    <.form
      for={%{}}
      action={~p"/users/log-out"}
      method="delete"
      id="logout-form"
      data-auto-submit
    >
      <%= if @return_to do %>
        <input type="hidden" name="return_to" value={@return_to} />
      <% end %>
      <noscript>
        <button
          type="submit"
          class={[
            "rounded-lg border border-white/[0.12] bg-white/[0.04]",
            "px-6 py-2 text-sm font-medium text-white/90",
            "transition-all duration-150",
            "hover:bg-white/[0.08] hover:border-white/[0.18] hover:text-white",
            "active:scale-[0.98]"
          ]}
        >
          Click here to sign out
        </button>
      </noscript>
    </.form>
  </div>
</Layouts.app>
