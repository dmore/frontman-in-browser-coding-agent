---
// Imports
// Components
import NavigationBar from '../components/ui/NavigationBar.astro'
import Main from '../components/ui/Main.astro'
import Footer from '../components/ui/Footer.astro'
// import Modal from '../components/blocks/modal/SignUp.astro'
import Header from '../components/blocks/head/Header.astro'
// Scripts
import Scriprs from '../components/scripts/LocalScripts.astro'
// Styles
import '../styles/global.css'
// Fonts
import '@fontsource-variable/inter'
import '@fontsource-variable/outfit'
// Data
import { configData } from '../config/config'

// Props
type Props = {
	title?: string
	description?: string
	ogImage?: string
	noindex?: boolean
	classes?: string
	article?: {
		publishedTime?: string
		modifiedTime?: string
		tags?: string[]
	}
}
// Page Metadata
const { title, description, ogImage, noindex, classes, article } = Astro.props
---

<!doctype html>
<html lang="en" class="scroll-animation dark relative">
	<Header title={title} description={description} ogImage={ogImage} noindex={noindex} article={article} />
	<body
		class:list={[
			{ ['scroll-animation']: configData.scrollAnimations },
			{ [`${classes}`]: classes }
		]}
	>
		<NavigationBar />
		<Main>
			<slot />
		</Main>
		<Footer />
		<!-- <Modal /> -->
		<!-- <Toast /> -->
		<Scriprs />
	</body>
</html>
