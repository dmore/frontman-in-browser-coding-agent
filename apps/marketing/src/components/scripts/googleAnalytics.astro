---
// Google Analytics tracking script
import { googleAnalyticsMeasurementID } from '../../../src/config/analytics.ts'
---

<script
	is:inline
	async
	src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsMeasurementID}`}></script>

<script is:inline data-ga-measurement-id={googleAnalyticsMeasurementID} id="ga-init">
	const measurementId = document.getElementById('ga-init').getAttribute('data-ga-measurement-id')
	window.dataLayer = window.dataLayer || []
	function gtag() {
		dataLayer.push(arguments)
	}
	gtag('js', new Date())
	gtag('config', measurementId)

	window.trackEvent = function(eventName, params) {
		gtag('event', eventName, params)
	}
</script>

<script is:inline>
	document.addEventListener('DOMContentLoaded', function() {
		document.body.addEventListener('click', function(e) {
			const target = e.target.closest('[data-ga-event]')
			if (target) {
				const eventName = target.getAttribute('data-ga-event')
				const eventCategory = target.getAttribute('data-ga-category') || 'engagement'
				const eventLabel = target.getAttribute('data-ga-label') || ''
				window.trackEvent(eventName, {
					event_category: eventCategory,
					event_label: eventLabel
				})
			}
		})
	})
</script>
