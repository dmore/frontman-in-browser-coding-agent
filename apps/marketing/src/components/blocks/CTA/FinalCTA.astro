---
// Final CTA Section
// ------------
// Description: Final call-to-action section with logo and button

// Components
// - UI
import Button from '../../ui/Button.astro'

// Props
type Props = {
	link?: string
}
const { link = '#install' } = Astro.props

// Logo
const logoImage = { src: '/logo.svg' }
---

<section id="final-cta" class="final-cta-section">
	<div class="container">
		<div class="cta-content">
			<img src={logoImage.src} alt="Frontman" class="cta-logo" width="192" height="192" loading="lazy" />
			<h2 class="cta-title">Done refreshing. Done guessing.</h2>
			<p class="cta-description">
				Your AI finally sees what you see. Click an element, describe what you want, and watch it happen — no more alt-tabbing, no more hallucinated layouts, no more broken diffs.
			</p>
			<div class="cta-buttons">
				<div class="cta-button">
					<Button size="lg" style="primary" link={link} data-ga-event="click_start_frontman" data-ga-category="conversion" data-ga-label="final_cta">Start Frontman</Button>
				</div>
				<a href="https://discord.gg/xk8uXJSvhC" target="_blank" rel="noopener noreferrer" class="cta-community-link" data-ga-event="click_join_discord" data-ga-category="engagement" data-ga-label="final_cta">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
						<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
					</svg>
					Or join our Discord community
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.final-cta-section {
		@apply relative overflow-hidden py-20 lg:py-32;
		background: white;
	}

	.container {
		@apply relative mx-auto px-6 max-w-7xl;
		display: flex;
		justify-content: center;
	}

	.cta-content {
		@apply flex flex-col items-start;
		max-width: 640px;
		text-align: left;
	}

	.cta-logo {
		@apply mb-8;
		filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.1));
	}

	.cta-title {
		@apply font-headings text-4xl lg:text-5xl font-bold text-black mb-6 w-full;
		line-height: 1.2;
	}

	.cta-description {
		@apply text-base lg:text-lg text-neutral-700 mb-8 w-full;
		line-height: 1.7;
	}

	.cta-buttons {
		@apply w-full flex flex-col gap-3;
	}

	.cta-button {
		@apply w-full;
	}

	.cta-community-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: #6b7280;
		font-size: 15px;
		font-weight: 450;
		text-decoration: none;
		transition: color 0.2s;
	}

	.cta-community-link:hover {
		color: #111827;
	}

	/* Responsive adjustments */
	@media (max-width: 1024px) {
		.cta-logo {
			width: 154px;
			height: 154px;
			@apply mb-6;
		}

		.cta-title {
			@apply text-3xl mb-5;
		}

		.cta-description {
			@apply text-base mb-6;
		}
	}

	@media (max-width: 640px) {
		.final-cta-section {
			padding-top: 2rem;
			padding-bottom: 2rem;
		}

		.cta-logo {
			width: 134px;
			height: 134px;
			@apply mb-5;
		}

		.cta-title {
			@apply text-2xl mb-4;
		}

		.cta-description {
			@apply text-sm mb-5;
		}
	}
</style>
