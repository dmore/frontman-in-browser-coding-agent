---
// IntegrationContextGrid
// ----------------------
// Shared "What Frontman Sees" section with a 2-column context card grid.
// Props:
// - title: Section heading (e.g. "What Frontman Sees in Your Next.js App")
// - intro: Intro paragraph text
// - items: Array of { category, items[] }
// Slot: Optional extra content before the grid (e.g. Vite's framework-specific grids)

type ContextGroup = {
	category: string
	items: string[]
}

type Props = {
	title: string
	intro: string
	items: ContextGroup[]
}

const { title, intro, items } = Astro.props
---

<section class="context-section">
	<div class="context-container">
		<h2 class="section-title">{title}</h2>
		<p class="context-intro">{intro}</p>

		<slot />

		<div class="context-grid">
			{items.map((group) => (
				<div class="context-card">
					<h3 class="context-card-title">{group.category}</h3>
					<ul class="context-list">
						{group.items.map((item) => (
							<li class="context-item">
								<svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
								{item}
							</li>
						))}
					</ul>
				</div>
			))}
		</div>

	</div>
</section>

<style>
	@reference "../../../styles/global.css";
	.context-section {
		background: #09090b;
		padding: 64px 24px;
		display: flex;
		justify-content: center;
	}
	.context-container {
		max-width: 900px;
		width: 100%;
	}
	.section-title {
		font-size: 32px;
		font-weight: 700;
		color: #fafafa;
		margin-bottom: 24px;
		letter-spacing: -0.02em;
	}
	.context-intro {
		font-size: 17px;
		line-height: 1.7;
		color: #a1a1aa;
		margin-bottom: 32px;
		max-width: 720px;
	}
	.context-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
	}
	.context-card {
		padding: 24px;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}
	.context-card-title {
		@apply font-headings;
		font-size: 18px;
		font-weight: 700;
		color: #fafafa;
		margin-bottom: 16px;
	}
	.context-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.context-item {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		font-size: 15px;
		color: #a1a1aa;
		padding: 6px 0;
	}
	.check-icon {
		color: #22c55e;
		flex-shrink: 0;
		margin-top: 3px;
	}

	/* Slot content styles (e.g. Vite's framework cards use these classes) */
	.context-container :global(.context-list) {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.context-container :global(.context-item) {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		font-size: 15px;
		color: #a1a1aa;
		padding: 6px 0;
	}
	.context-container :global(.check-icon) {
		color: #22c55e;
		flex-shrink: 0;
		margin-top: 3px;
	}
	.context-container :global(.framework-grid) {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 20px;
		margin-bottom: 20px;
	}
	.context-container :global(.framework-card) {
		padding: 24px;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}
	.context-container :global(.framework-card-title) {
		font-size: 20px;
		font-weight: 700;
		color: #A259FF;
		margin-bottom: 16px;
	}
	.context-container :global(.vite-grid) {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
	}

	@media (max-width: 768px) {
		.context-section { padding: 40px 20px; }
		.section-title { font-size: 24px; }
		.context-grid { grid-template-columns: 1fr; }
		.context-container :global(.framework-grid) { grid-template-columns: 1fr; }
		.context-container :global(.vite-grid) { grid-template-columns: 1fr; }
	}
</style>
