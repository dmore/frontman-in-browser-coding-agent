---
// Hero Section for Blog Posts
// ------------
// Description: A hero section (page header) for the post pages.
// Properties:
// - tags: An array of tags for the post
// - title: The title of the section (usually the title of the post)
// - author: The author of the post
// - pubDate: The publish date of the post (Date object)
// - updatedDate: Optional last-updated date (Date object)

// Components
// - Layout
import Section from '../../../components/ui/Section.astro'
import Row from '../../../components/ui/Row.astro'
import Col from '../../../components/ui/Col.astro'
// - UI
import Badge from '../../../components/ui/Badge.astro'
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro'

// Props
type Props = {
	tags?: any
	title: string
	author?: string
	authorRole?: string
	pubDate?: Date
	updatedDate?: Date
}
const { tags, title, author, authorRole, pubDate, updatedDate } = Astro.props

const formatDate = (date: Date) =>
	date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })

const publishDateFormatted = pubDate ? formatDate(pubDate) : undefined
const publishDateISO = pubDate ? pubDate.toISOString() : undefined
const updatedDateFormatted = updatedDate ? formatDate(updatedDate) : undefined
const updatedDateISO = updatedDate ? updatedDate.toISOString() : undefined
---

<Section id="post-intro" classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="12" align="center">
			<header class="post-header">
				<Breadcrumbs classes="mb-6" />
				<h1 class="post-header__title">
					{title}
				</h1>
			{
				author ? (
					<p class="page-header__text">
						Written by <a href="/about/" class="author-link">{author}</a>{authorRole && (
							<>, {authorRole}</>
						)}{publishDateISO && (
							<> on <time datetime={publishDateISO}>{publishDateFormatted}</time></>
						)}
					</p>
				) : (
					publishDateISO && <p class="page-header__text">Published on <time datetime={publishDateISO}>{publishDateFormatted}</time></p>
				)
			}
			{
				updatedDateISO && (
					<p class="page-header__text page-header__updated">
						Last updated: <time datetime={updatedDateISO}>{updatedDateFormatted}</time>
					</p>
				)
			}
			</header>
			{
				tags && (
					<div class="post-header__tags">
						{tags.map((tag: string) => (
							<Badge name={tag} link={`/blog/tags/${tag}/`} classes="capitalize" />
						))}
					</div>
				)
			}
		</Col>
	</Row>
</Section>

<style>
	@reference "../../../styles/global.css";
	.page-header {
		@apply mx-auto max-w-4xl;
	}
	.page-header__text {
		@apply text-lg leading-relaxed;
	}
	.page-header__updated {
		@apply text-base text-neutral-500 dark:text-neutral-400 mt-1;
	}
	.author-link {
		@apply text-primary-600 dark:text-primary-400 no-underline hover:underline;
	}
	.post-header__tags {
		@apply mt-6 flex flex-row items-center justify-center gap-2 pb-2;
	}
</style>
