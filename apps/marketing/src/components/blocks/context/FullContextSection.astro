---
// Full Context Section
// ------------
// Description: A section explaining how Frontman understands your design system

// Components
// - Layout
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
---

<section id="full-context" class="full-context-section">
	<div class="container">
		<Row classes="gap-12">
			<!-- Left side: Visual — Design-to-Code illustration -->
			<Col spanMobile="12" span="6">
				<div class="context-visual">
					<div class="design-system-diagram">
						<!-- Design mockup card -->
						<div class="ds-card ds-card--design">
							<div class="ds-card__header">
								<div class="ds-card__dots">
									<span class="ds-dot ds-dot--red"></span>
									<span class="ds-dot ds-dot--yellow"></span>
									<span class="ds-dot ds-dot--green"></span>
								</div>
								<span class="ds-card__label">Your Design</span>
							</div>
							<div class="ds-card__body">
								<div class="ds-swatch-row">
									<span class="ds-swatch" style="background:#A259FF;"></span>
									<span class="ds-swatch" style="background:#56CCF2;"></span>
									<span class="ds-swatch" style="background:#27AE60;"></span>
									<span class="ds-swatch" style="background:#F2994A;"></span>
								</div>
								<div class="ds-type-row">
									<span class="ds-type-sample ds-type-sample--heading">Aa</span>
									<span class="ds-type-sample ds-type-sample--body">Aa</span>
								</div>
								<div class="ds-component-row">
									<span class="ds-btn-sample">Button</span>
									<span class="ds-input-sample"></span>
								</div>
							</div>
						</div>

						<!-- Arrow / connection -->
						<div class="ds-arrow">
							<img src="/logo.svg" alt="Frontman" class="ds-arrow__logo" width="48" height="48" loading="lazy" />
							<svg class="ds-arrow__svg" viewBox="0 0 24 80" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
								<path d="M12 0 L12 60 M6 54 L12 66 L18 54" stroke="#A259FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>

						<!-- Live code card -->
						<div class="ds-card ds-card--code">
							<div class="ds-card__header">
								<div class="ds-card__dots">
									<span class="ds-dot ds-dot--red"></span>
									<span class="ds-dot ds-dot--yellow"></span>
									<span class="ds-dot ds-dot--green"></span>
								</div>
								<span class="ds-card__label">Your Code</span>
							</div>
							<div class="ds-card__body ds-card__body--code">
								<code class="ds-code-line"><span class="ds-tok-keyword">const</span> <span class="ds-tok-var">theme</span> = {</code>
								<code class="ds-code-line ds-code-indent"><span class="ds-tok-prop">primary</span>: <span class="ds-tok-string">"#A259FF"</span>,</code>
								<code class="ds-code-line ds-code-indent"><span class="ds-tok-prop">radius</span>: <span class="ds-tok-string">"8px"</span>,</code>
								<code class="ds-code-line">}</code>
							</div>
						</div>

						<div class="ds-scan-line"></div>
					</div>
				</div>
			</Col>

			<!-- Right side: Content -->
			<Col spanMobile="12" span="6">
			<div class="context-content">
				<h2 class="context-title">
					Your Design System.<br/>Your Rules.
				</h2>

				<div class="context-text">
					<p>
						No more pixel-pushing in code you didn't write. Frontman understands your components, your design tokens, and your layout conventions — so every edit stays on-brand.
					</p>
					<p>
						Spot a misaligned element? A color that feels off? Point at it, describe what you see, and Frontman refines the source to match your vision. No redlines, no handoff gaps, no compromises.
					</p>
				</div>
			</div>
			</Col>
		</Row>
	</div>
</section>

<style>
	@reference "../../../styles/global.css";
	.full-context-section {
		@apply relative overflow-hidden py-20 lg:py-32;
		background-color: #1a1a1a;
		background-image:
			repeating-linear-gradient(
				60deg,
				transparent,
				transparent 50px,
				rgba(162, 89, 255, 0.15) 50px,
				rgba(162, 89, 255, 0.15) 51px
			),
			repeating-linear-gradient(
				-60deg,
				transparent,
				transparent 50px,
				rgba(162, 89, 255, 0.15) 50px,
				rgba(162, 89, 255, 0.15) 51px
			);
		background-size: 100px 100px;
	}

	.container {
		@apply relative mx-auto px-6 max-w-7xl;
	}

	/* Visual Side */
	.context-visual {
		@apply relative flex items-center justify-center;
		min-height: 400px;
	}

	/* Design System Diagram */
	.design-system-diagram {
		@apply relative flex flex-col items-center;
		width: 100%;
		max-width: 340px;
		gap: 0;
	}

	/* Cards */
	.ds-card {
		width: 100%;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
	}
	.ds-card--design {
		background: #2a2a2e;
	}
	.ds-card--code {
		background: #1e1e24;
	}
	.ds-card__header {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 10px 14px;
		background: rgba(255, 255, 255, 0.05);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.ds-card__dots {
		display: flex;
		gap: 6px;
	}
	.ds-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}
	.ds-dot--red { background: #ff5f57; }
	.ds-dot--yellow { background: #febc2e; }
	.ds-dot--green { background: #28c840; }
	.ds-card__label {
		font-family: 'SF Pro Display', system-ui, sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.5);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.ds-card__body {
		padding: 18px 16px;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	/* Swatches */
	.ds-swatch-row {
		display: flex;
		gap: 10px;
	}
	.ds-swatch {
		width: 36px;
		height: 36px;
		border-radius: 8px;
		box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
	}

	/* Typography samples */
	.ds-type-row {
		display: flex;
		align-items: baseline;
		gap: 16px;
	}
	.ds-type-sample {
		font-family: 'SF Pro Display', system-ui, sans-serif;
		color: white;
	}
	.ds-type-sample--heading {
		font-size: 28px;
		font-weight: 700;
	}
	.ds-type-sample--body {
		font-size: 16px;
		font-weight: 400;
		opacity: 0.6;
	}

	/* Component samples */
	.ds-component-row {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.ds-btn-sample {
		display: inline-block;
		padding: 6px 18px;
		background: #A259FF;
		color: white;
		border-radius: 6px;
		font-size: 13px;
		font-weight: 600;
		font-family: 'SF Pro Display', system-ui, sans-serif;
	}
	.ds-input-sample {
		flex: 1;
		height: 32px;
		border-radius: 6px;
		border: 1px solid rgba(255, 255, 255, 0.15);
		background: rgba(255, 255, 255, 0.05);
	}

	/* Arrow connector */
	.ds-arrow {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0;
		padding: 4px 0;
		position: relative;
		z-index: 10;
	}
	.ds-arrow__logo {
		width: 40px;
		height: 40px;
		filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.3));
	}
	.ds-arrow__svg {
		width: 24px;
		height: 48px;
	}

	/* Code block */
	.ds-card__body--code {
		gap: 4px;
		font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
		font-size: 13px;
		line-height: 1.6;
	}
	.ds-code-line {
		display: block;
		white-space: pre;
	}
	.ds-code-indent {
		padding-left: 1.5em;
	}
	.ds-tok-keyword { color: #c678dd; }
	.ds-tok-var { color: #e06c75; }
	.ds-tok-prop { color: #56b6c2; }
	.ds-tok-string { color: #98c379; }

	/* Scanning animation overlay */
	.ds-scan-line {
		@apply absolute left-0 right-0;
		height: 2px;
		background: linear-gradient(90deg, transparent, #A259FF, transparent);
		animation: ds-scan 3s ease-in-out infinite;
		top: 0;
		z-index: 30;
		pointer-events: none;
	}

	@keyframes ds-scan {
		0% {
			top: 0;
			opacity: 0;
		}
		50% {
			opacity: 1;
		}
		100% {
			top: 100%;
			opacity: 0;
		}
	}

	/* Content Side */
	.context-content {
		@apply flex flex-col justify-center h-full py-8 lg:py-0;
	}

	.context-title {
		@apply font-headings text-4xl lg:text-5xl font-bold mb-8;
		color: white;
		line-height: 1.2;
	}

	.context-text {
		@apply space-y-4;
	}

	.context-text p {
		@apply text-base lg:text-lg leading-relaxed;
		color: rgba(255, 255, 255, 0.9);
	}

	/* Responsive adjustments */
	@media (max-width: 1024px) {
		.context-visual {
			min-height: auto;
		}

		.design-system-diagram {
			max-width: 300px;
		}

		.context-title {
			@apply text-3xl mb-6;
		}

		.context-text p {
			@apply text-base;
		}
	}

	@media (max-width: 640px) {
		.full-context-section {
			padding-top: 2rem;
			padding-bottom: 2rem;
		}

		.design-system-diagram {
			max-width: 100%;
		}

		.context-title {
			@apply text-2xl mb-5;
		}
	}
</style>
