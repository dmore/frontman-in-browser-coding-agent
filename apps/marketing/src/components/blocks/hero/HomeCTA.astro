---
// Home page CTA Section
// ------------
// Description: A centered call to action section that contains: a title, text, a user review snippet, a button and a image.

// Components
// - UI
import OpenSourceBadge from '../../ui/OpenSourceBadge.astro'
import { Image } from 'astro:assets'
import Button from '../../ui/Button.astro'

// Content
// - Hero Image
import heroImage from '../../../assets/frontman-example.png'
// - Background Pattern
import gridNetBackground from '../../../assets/grid-net-background.svg'
// - Logo (from public folder)
const logoImage = { src: '/logo.svg' }
---

<section id="intro" class="hero-section bg-primary-500">
	<div class="hero-section__bg">
		<img src={gridNetBackground.src} alt="" class="hero-section__bg-image" width="1440" height="900" fetchpriority="high" />
	</div>
	<div class="hero-section__container">
		<div class="hero-section__content">
			<div class="hero-section__text">
				<img src={logoImage.src} alt="Frontman logo" class="hero-section__logo" width="143" height="143" />
				<OpenSourceBadge classes="mb-6" />
				<h1 class="hero-section__title">AI that sees your DOM and edits your frontend</h1>
				<p class="hero-section__subtitle">Frontman lives inside your browser, sees your live DOM, and turns plain English into real code changes — no more refresh-and-check cycles</p>
				<div class="hero-section__cta">
					<Button size="lg" style="white" link="#install">Get Started For Free</Button>
					<a href="https://discord.gg/J77jBzMM" target="_blank" rel="noopener noreferrer" class="hero-section__community-link">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
							<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
						</svg>
						Join the Community
					</a>
					<a href="https://github.com/frontman-ai/frontman" target="_blank" rel="noopener noreferrer" class="hero-section__github-link">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 48 48" height="20" width="20" aria-hidden="true">
							<path fill="currentColor" fill-rule="evenodd" d="M24 1.5C11.574 1.5 1.5 11.574 1.5 24c0 9.934 6.441 18.362 15.382 21.34 1.125.207 1.536-.488 1.536-1.084 0-.534-.02-1.95-.03-3.828-6.258 1.36-7.578-3.016-7.578-3.016-1.023-2.598-2.497-3.29-2.497-3.29-2.04-1.395.155-1.367.155-1.367 2.256.158 3.443 2.316 3.443 2.316 2.004 3.434 5.26 2.442 6.54 1.867.204-1.452.784-2.443 1.426-3.004-4.997-.568-10.252-2.498-10.252-11.12 0-2.456.878-4.466 2.318-6.04-.232-.57-1.005-2.858.22-5.957 0 0 1.89-.605 6.192 2.307a21.598 21.598 0 0 1 5.646-.76c1.916.01 3.845.26 5.646.76 4.298-2.912 6.184-2.307 6.184-2.307 1.229 3.099.456 5.387.224 5.957 1.443 1.574 2.315 3.584 2.315 6.04 0 8.643-5.262 10.546-10.274 11.1.808.696 1.528 2.07 1.528 4.17 0 3.01-.028 5.44-.028 6.178 0 .6.406 1.3 1.548 1.08C40.066 42.356 46.5 33.93 46.5 24 46.5 11.574 36.426 1.5 24 1.5Z" clip-rule="evenodd"></path>
						</svg>
						Star on GitHub
					</a>
				</div>
			</div>
			<div class="hero-section__image-wrapper">
				<Image
					src={heroImage}
					alt="Frontman - AI Frontend Editing"
					class="hero-section__image"
					format="webp"
					fetchpriority="high"
					loading="eager"
					decoding="sync"
					widths={[400, 640, 964]}
					sizes="(max-width: 1023px) 100vw, 964px"
				/>
			</div>
		</div>
	</div>
</section>

<style>
	.hero-section {
		position: relative;
		overflow: hidden;
		min-height: 600px;
	}
	@media (max-width: 1023px) {
		.hero-section {
			min-height: auto;
		}
	}
	.hero-section__bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		opacity: 0.3;
	}
	.hero-section__bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}
	.hero-section__container {
		position: relative;
		z-index: 1;
		padding: 40px 24px;
		width: 100%;
	}
	@media (min-width: 1024px) {
		.hero-section__container {
			padding: 70px 0 90px 48px;
		}
	}
	.hero-section__content {
		display: flex;
		flex-direction: column;
		gap: 24px;
		align-items: flex-start;
		max-width: 1440px;
		margin: 0 auto;
		position: relative;
	}
	@media (min-width: 1024px) {
		.hero-section__content {
			flex-direction: row;
			align-items: center;
			gap: 48px;
		}
	}
	.hero-section__text {
		flex: 0 0 auto;
		width: 100%;
		max-width: 600px;
	}
	@media (min-width: 1024px) {
		.hero-section__text {
			width: 45%;
			max-width: none;
			padding-right: 48px;
		}
	}
	@media (max-width: 1023px) {
		.hero-section__text {
			max-width: 100%;
		}
	}
	.hero-section__logo {
		display: none;
	}
	@media (min-width: 1024px) {
		.hero-section__logo {
			display: block;
			width: 143px;
			height: 143px;
			margin-bottom: 32px;
		}
	}
	.hero-section__title {
		font-family: 'SF Pro Display', system-ui, helvetica, sans-serif;
		font-size: 36px;
		line-height: 42px;
		font-weight: 700;
		color: white;
		margin-bottom: 16px;
		max-width: 100%;
	}
	@media (min-width: 1024px) {
		.hero-section__title {
			font-size: 64px;
			line-height: 70px;
			margin-bottom: 24px;
			max-width: 700px;
		}
	}
	.hero-section__subtitle {
		font-size: 16px;
		line-height: 22px;
		color: white;
		margin-bottom: 24px;
		max-width: 100%;
	}
	@media (min-width: 1024px) {
		.hero-section__subtitle {
			font-size: 18px;
			line-height: 25px;
			margin-bottom: 32px;
			max-width: 700px;
		}
	}
	.hero-section__cta {
		display: flex;
		flex-direction: column;
		gap: 12px;
		max-width: 100%;
		width: 100%;
	}
	.hero-section__cta .button {
		width: 100%;
	}
	@media (min-width: 1024px) {
		.hero-section__cta {
			flex-direction: row;
			align-items: center;
			gap: 16px;
			max-width: none;
		}
		.hero-section__cta .button {
			width: auto;
		}
	}
	.hero-section__github-link,
	.hero-section__community-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: white;
		font-family: 'SF Pro Display', system-ui, helvetica, sans-serif;
		font-weight: 480;
		font-size: 15px;
		line-height: 22px;
		text-decoration: none;
		white-space: nowrap;
		background: rgba(255, 255, 255, 0.15);
		padding: 8px 16px;
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.25);
		transition: background 0.2s, border-color 0.2s;
	}
	.hero-section__github-link:hover,
	.hero-section__community-link:hover {
		background: rgba(255, 255, 255, 0.25);
		border-color: rgba(255, 255, 255, 0.4);
	}
	.hero-section__image-wrapper {
		flex: 1 1 auto;
		width: 100%;
		overflow: visible;
		display: flex;
		justify-content: center;
		align-items: center;
		margin-right: 0;
		padding: 0;
	}
	@media (min-width: 1024px) {
		.hero-section__image-wrapper {
			width: 55%;
			max-width: none;
			justify-content: flex-end;
			padding: 0;
			margin-right: -30px;
		}
	}
	.hero-section__image {
		width: 964px;
		height: auto;
		object-fit: cover;
		object-position: left center;
		display: block;
	}
	@media (max-width: 1023px) {
		.hero-section__image {
			width: 100%;
			max-width: 964px;
		}
	}
</style>
