---
import { marked } from 'marked'
import termsContent from '../data/markdown-files/terms.md?raw'
import Layout from '../layouts/Layout.astro'

const SEO = {
	title: 'Frontman | Terms of Service',
	description:
		'Read the Terms of Service for Frontman. Learn about your rights, responsibilities, and the rules governing your use of the Frontman platform.'
}

const termsHtml = await marked.parse(termsContent)
const updatedAtMatch = termsContent.match(/_Last updated:\s*(.+)_/)
const updatedAt = updatedAtMatch?.[1] ?? null
const contentHtml = termsHtml.replace(/<p><em>Last updated:[\s\S]*?<\/em><\/p>\s*$/u, '')
---

<Layout title={SEO.title} description={SEO.description}>
	<div class="legal-page">
		<div class="legal-container">
			<p class="legal-label">Legal</p>
			<h1 class="legal-title">Terms of Service</h1>
			{updatedAt && <p class="legal-updated">Last updated: {updatedAt}</p>}

			<div class="legal-content" set:html={contentHtml}></div>
		</div>
	</div>
</Layout>

<style>
	@reference "../styles/global.css";
	.legal-page {
		background: #09090b;
		color: #fafafa;
		padding: 80px 24px 120px;
		display: flex;
		justify-content: center;
		min-height: 100vh;
	}

	.legal-container {
		max-width: 720px;
		width: 100%;
	}

	.legal-label {
		@apply font-mono;
		font-size: 13px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #71717a;
		margin-bottom: 12px;
	}

	.legal-title {
		font-size: 42px;
		font-weight: 700;
		line-height: 1.1;
		margin-bottom: 12px;
		letter-spacing: -0.02em;
		color: #fafafa;
	}

	.legal-updated {
		font-size: 14px;
		color: #71717a;
		margin-bottom: 64px;
	}

	.legal-content :global(h2) {
		font-size: 22px;
		font-weight: 600;
		color: #fafafa;
		margin-top: 48px;
		margin-bottom: 16px;
		letter-spacing: -0.01em;
	}

	.legal-content :global(h2:first-child) {
		margin-top: 0;
	}

	.legal-content :global(h3) {
		font-size: 17px;
		font-weight: 600;
		color: #d4d4d8;
		margin-top: 24px;
		margin-bottom: 8px;
	}

	.legal-content :global(p) {
		font-size: 15px;
		line-height: 1.7;
		color: #a1a1aa;
		margin-bottom: 12px;
		max-width: 620px;
	}

	.legal-content :global(a) {
		color: #a78bfa;
		text-decoration: underline;
		text-underline-offset: 2px;
		transition: color 0.2s;
	}

	.legal-content :global(a:hover) {
		color: #c4b5fd;
	}

	.legal-content :global(ul) {
		list-style: disc;
		padding-left: 24px;
		margin-bottom: 12px;
	}

	.legal-content :global(li) {
		font-size: 15px;
		line-height: 1.7;
		color: #a1a1aa;
		margin-bottom: 4px;
	}

	.legal-content :global(strong) {
		color: #d4d4d8;
		font-weight: 600;
	}

	.legal-content :global(hr) {
		display: none;
	}

	@media (max-width: 640px) {
		.legal-page {
			padding: 48px 20px 80px;
		}

		.legal-title {
			font-size: 32px;
		}

		.legal-updated {
			margin-bottom: 48px;
		}
	}
</style>
