---
import Layout from '../../layouts/Layout.astro'
import Section from '../../components/ui/Section.astro'
import Row from '../../components/ui/Row.astro'
import Col from '../../components/ui/Col.astro'
import { getCollection } from 'astro:content'

const SEO = {
	title: 'Frontend Glossary | Frontman',
	description:
		'A comprehensive glossary of frontend development terms — from Virtual DOM to WebAssembly. Clear definitions for developers, engineering managers, and tech leads.'
}

const entries = await getCollection('glossary')
const sorted = entries.sort((a, b) => a.data.title.localeCompare(b.data.title))
const entryMap = new Map(sorted.map((entry) => [entry.id, entry]))
type GlossaryEntry = (typeof sorted)[number]
const isGlossaryEntry = (entry: GlossaryEntry | undefined): entry is GlossaryEntry => entry !== undefined

const grouped = new Map<string, typeof sorted>()
for (const entry of sorted) {
	const letter = entry.data.title[0].toUpperCase()
	if (!grouped.has(letter)) grouped.set(letter, [])
	grouped.get(letter)!.push(entry)
}
const letters = [...grouped.keys()].sort()

const topicGroups = [
	{
		title: 'Performance & Core Web Vitals',
		description: 'Key terms for loading speed, rendering, bundle size, and web performance work.',
		ids: ['first-contentful-paint', 'largest-contentful-paint', 'time-to-first-byte', 'tree-shaking']
	},
	{
		title: 'Rendering & Architecture',
		description: 'Concepts that explain how modern frontend apps render, stream, and hydrate.',
		ids: ['server-side-rendering', 'static-site-generation', 'partial-hydration', 'islands-architecture']
	},
	{
		title: 'React, State & Data Flow',
		description: 'A quick path through component architecture, state management, and reactivity.',
		ids: ['react', 'redux', 'signals', 'state-management']
	},
	{
		title: 'Security & SEO',
		description: 'Terms that matter for crawlability, structured data, headers, and search visibility.',
		ids: ['content-security-policy', 'technical-seo', 'schema-org', 'robots-txt-file']
	}
]

const curatedGroups = topicGroups
	.map((group) => ({
		...group,
		entries: group.ids.map((id) => entryMap.get(id)).filter(isGlossaryEntry)
	}))
	.filter((group) => group.entries.length > 0)

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'DefinedTermSet',
	name: 'Frontend Development Glossary',
	description: SEO.description,
	url: 'https://frontman.sh/glossary/',
	numberOfItems: entries.length
}
---

<Layout title={SEO.title} description={SEO.description}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

	<Section id="glossary-hero" classes="bg-neutral-50 dark:bg-neutral-900">
		<Row>
			<Col span="12" align="center">
				<h1 class="glossary-hero__title">Frontend Glossary</h1>
				<p class="glossary-hero__description">
					{entries.length} terms covering frontend development, performance, security, SEO, and
					more.
				</p>
				<p class="glossary-hero__supporting-text">
					Use the glossary when you hit an unfamiliar frontend term in the docs, a Lighthouse
					audit, or a framework guide. Each entry is designed to be a quick explanation you can
					follow with related concepts.
				</p>
			</Col>
		</Row>
	</Section>

	<Section id="glossary-topics" padding="top">
		<Row>
			<Col span="12">
				<div class="glossary-topics-header">
					<h2>Popular topic clusters</h2>
					<p>Start with a curated path if you are exploring a concept area instead of a single term.</p>
				</div>
				<div class="glossary-topic-grid">
					{curatedGroups.map((group) => (
						<section class="glossary-topic-card">
							<h3 class="glossary-topic-card__title">{group.title}</h3>
							<p class="glossary-topic-card__description">{group.description}</p>
							<ul class="glossary-topic-card__list">
								{group.entries.map((entry) => (
									<li>
										<a href={`/glossary/${entry.id}/`}>{entry.data.title}</a>
									</li>
								))}
							</ul>
						</section>
					))}
				</div>
			</Col>
		</Row>
	</Section>

	<Section id="glossary-index" padding="top">
		<Row>
			<Col span="12">
				<nav class="glossary-nav" aria-label="Glossary alphabet">
					{
						letters.map((letter) => (
							<a href={`#${letter}`} class="glossary-nav__letter">
								{letter}
							</a>
						))
					}
				</nav>
			</Col>
		</Row>
	</Section>

	<Section id="glossary-list" padding="bottom">
		<Row>
			<Col span="12">
				{
					letters.map((letter) => (
						<div class="glossary-group" id={letter}>
							<h2 class="glossary-group__letter">{letter}</h2>
							<ul class="glossary-group__list">
								{grouped.get(letter)!.map((entry) => (
									<li>
										<a href={`/glossary/${entry.id}/`} class="glossary-term">
											<span class="glossary-term__title">{entry.data.title}</span>
											<span class="glossary-term__description">
												{entry.data.description}
											</span>
										</a>
									</li>
								))}
							</ul>
						</div>
					))
				}
			</Col>
		</Row>
	</Section>
</Layout>

<style>
	@reference "../../styles/global.css";
	.glossary-hero__title {
		@apply text-4xl font-bold lg:text-6xl;
	}
	.glossary-hero__description {
		@apply mt-4 text-lg leading-relaxed text-neutral-500 dark:text-neutral-400;
	}
	.glossary-hero__supporting-text {
		@apply mx-auto mt-4 max-w-3xl text-base leading-7 text-neutral-600 dark:text-neutral-300;
	}
	.glossary-topics-header {
		@apply mb-8;
	}
	.glossary-topics-header p {
		@apply mt-3 text-base leading-7 text-neutral-600 dark:text-neutral-300;
	}
	.glossary-topic-grid {
		@apply grid gap-4 lg:grid-cols-2;
	}
	.glossary-topic-card {
		@apply rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-800 dark:bg-neutral-900;
	}
	.glossary-topic-card__title {
		@apply font-headings text-xl font-semibold text-neutral-900 dark:text-white;
	}
	.glossary-topic-card__description {
		@apply mt-2 text-sm leading-6 text-neutral-600 dark:text-neutral-300;
	}
	.glossary-topic-card__list {
		@apply mt-4 space-y-2;
	}
	.glossary-topic-card__list a {
		@apply text-sm font-medium text-primary-600 underline underline-offset-4 hover:text-primary-500 dark:text-primary-400 dark:hover:text-primary-300;
	}
	.glossary-nav {
		@apply flex flex-wrap justify-center gap-2;
	}
	.glossary-nav__letter {
		@apply flex h-10 w-10 items-center justify-center rounded-lg border border-neutral-200 font-headings text-sm font-semibold text-neutral-700 transition-colors hover:border-primary-500 hover:bg-primary-50 hover:text-primary-600 dark:border-neutral-700 dark:text-neutral-200 dark:hover:border-primary-400 dark:hover:bg-primary-950 dark:hover:text-primary-400;
	}
	.glossary-group {
		@apply mb-12;
	}
	.glossary-group__letter {
		@apply mb-4 border-b border-neutral-200 pb-2 text-2xl font-bold dark:border-neutral-700;
	}
	.glossary-group__list {
		@apply grid gap-3 sm:grid-cols-2 lg:grid-cols-3;
	}
	.glossary-term {
		@apply flex flex-col rounded-lg border border-neutral-200 p-4 transition-all hover:border-primary-300 hover:shadow-sm dark:border-neutral-700 dark:hover:border-primary-600;
	}
	.glossary-term__title {
		@apply font-headings font-semibold text-neutral-700 dark:text-neutral-100;
	}
	.glossary-term__description {
		@apply mt-1 line-clamp-2 text-sm text-neutral-500 dark:text-neutral-400;
	}
</style>
