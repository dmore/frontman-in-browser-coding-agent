---
import Layout from '../../layouts/Layout.astro'
import Button from '../../components/ui/Button.astro'
import { getCollection } from 'astro:content'

const entries = await getCollection('lighthouse')

const categoryLabels: Record<string, string> = {
	performance: 'Performance',
	accessibility: 'Accessibility',
	seo: 'SEO',
	'best-practices': 'Best Practices'
}

const categoryOrder = ['performance', 'accessibility', 'seo', 'best-practices']

const grouped = categoryOrder.map((cat) => ({
	key: cat,
	label: categoryLabels[cat],
	entries: entries
		.filter((e) => e.data.category === cat)
		.sort((a, b) => b.data.weight - a.data.weight)
})).filter((g) => g.entries.length > 0)

const SEO = {
	title: 'How to Fix Lighthouse Issues | Frontman',
	description:
		'Step-by-step guides to fix every major Google Lighthouse audit. Learn the manual approach, then see how Frontman fixes each issue automatically.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<!-- Hero -->
	<section class="hero-section">
		<div class="hero-container">
			<p class="hero-label">Lighthouse</p>
			<h1 class="hero-title">How to Fix Lighthouse Issues</h1>
			<p class="hero-subtitle">
				Step-by-step guides for the most impactful Google Lighthouse audits. Each guide explains the issue, walks through the manual fix, and shows how Frontman handles it automatically.
			</p>
		</div>
	</section>

	<!-- Guides grouped by category -->
	{grouped.map((group) => (
		<section class="content-section">
			<div class="content-container">
				<h2 class="category-heading">{group.label}</h2>
				<div class="guides-grid">
					{group.entries.map((entry) => (
						<a href={`/lighthouse/${entry.id}/`} class="guide-card">
							<div class="guide-card__category">{categoryLabels[entry.data.category]}</div>
							<h3 class="guide-card__title">{entry.data.title}</h3>
							<p class="guide-card__desc">{entry.data.description}</p>
							<span class="guide-card__link">Read guide &rarr;</span>
						</a>
					))}
				</div>
			</div>
		</section>
	))}

	<!-- CTA -->
	<section class="cta-section">
		<div class="cta-container">
			<h2 class="cta-title">Stop fixing Lighthouse issues manually</h2>
			<p class="cta-text">
				Frontman runs Lighthouse audits inside the browser, reads the results, and fixes the issues — all in one session. No tab switching. No copy-pasting audit output.
			</p>
			<div class="cta-buttons">
				<Button link="https://frontman.sh/blog/getting-started/" style="primary" size="lg">Get Started</Button>
				<Button link="https://frontman.sh/blog/lighthouse-audits-without-leaving-the-browser/" style="white" size="lg">See How It Works</Button>
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero-section {
		background: #09090b;
		color: #fafafa;
		padding: 100px 24px 80px;
		text-align: center;
	}
	.hero-container {
		max-width: 720px;
		margin: 0 auto;
	}
	.hero-label {
		font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
		font-size: 13px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #A259FF;
		margin-bottom: 12px;
	}
	.hero-title {
		font-size: 48px;
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.025em;
		margin-bottom: 16px;
	}
	.hero-subtitle {
		font-size: 18px;
		color: #a1a1aa;
		line-height: 1.65;
		max-width: 560px;
		margin: 0 auto;
	}

	.content-section {
		background: #09090b;
		padding: 40px 24px 60px;
	}
	.content-container {
		max-width: 960px;
		margin: 0 auto;
	}
	.category-heading {
		font-size: 24px;
		font-weight: 600;
		color: #fafafa;
		margin-bottom: 24px;
		padding-bottom: 12px;
		border-bottom: 1px solid #27272a;
		letter-spacing: -0.01em;
	}

	.guides-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 16px;
		margin-bottom: 40px;
	}
	@media (min-width: 640px) {
		.guides-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	.guide-card {
		display: block;
		padding: 24px;
		border: 1px solid #27272a;
		border-radius: 12px;
		background: #111113;
		text-decoration: none;
		transition: border-color 0.2s, background 0.2s;
	}
	.guide-card:hover {
		border-color: #A259FF66;
		background: #18181b;
	}
	.guide-card__category {
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #A259FF;
		margin-bottom: 8px;
	}
	.guide-card__title {
		font-size: 17px;
		font-weight: 600;
		color: #fafafa;
		line-height: 1.35;
		margin-bottom: 8px;
	}
	.guide-card__desc {
		font-size: 14px;
		color: #71717a;
		line-height: 1.55;
		margin-bottom: 12px;
	}
	.guide-card__link {
		font-size: 14px;
		font-weight: 500;
		color: #A259FF;
	}

	.cta-section {
		background: #111113;
		padding: 80px 24px;
		text-align: center;
		border-top: 1px solid #27272a;
	}
	.cta-container {
		max-width: 560px;
		margin: 0 auto;
	}
	.cta-title {
		font-size: 32px;
		font-weight: 700;
		color: #fafafa;
		margin-bottom: 12px;
		letter-spacing: -0.02em;
	}
	.cta-text {
		font-size: 17px;
		color: #a1a1aa;
		line-height: 1.65;
		margin-bottom: 32px;
	}
	.cta-buttons {
		display: flex;
		gap: 12px;
		justify-content: center;
		flex-wrap: wrap;
	}

	@media (max-width: 640px) {
		.hero-section {
			padding: 64px 20px 48px;
		}
		.hero-title {
			font-size: 32px;
		}
		.content-section {
			padding: 24px 20px 40px;
		}
	}
</style>
