---
import Layout from '../layouts/Layout.astro'

const SEO = {
	title: 'Frontman Pricing',
	description:
		'Frontman is free and open source during early access. Learn what is included today, when model-provider charges still apply, and where future plan details will appear.'
}

const highlights = [
	'Frontman itself is free during early access',
	'Open-source codebase with normal local development workflows',
	'Visual editing, annotations, screenshots, file edits, and git-friendly diffs',
	'Bring your own provider keys or use supported OAuth sign-in options where available'
]

const costs = [
	'If you connect paid model providers like Anthropic, OpenAI, or OpenRouter, those providers may bill you under their own pricing',
	'Self-hosting, local dev infrastructure, and your own cloud resources remain your responsibility',
	'When Frontman launches paid hosted plans, this page will list plan limits, billing, and team features directly'
]

const faqs = [
	{
		question: 'Is Frontman free right now?',
		answer:
			'Yes. Frontman is currently free and open source during early access. You can install it, run it locally, and use the core workflow without a Frontman subscription.'
	},
	{
		question: 'Do I need a credit card?',
		answer:
			'Not for Frontman itself during early access. If you choose to connect a paid AI provider with your own API key, that provider may bill you separately under its normal pricing.'
	},
	{
		question: 'Why might I still see model charges?',
		answer:
			'Frontman can route requests through providers like Anthropic, OpenAI, or OpenRouter. If you bring your own key, inference usage is billed by that provider, not by Frontman.'
	},
	{
		question: 'Can I self-host Frontman?',
		answer:
			'Yes. Frontman includes self-hosting documentation. If you want full control over deployment and infrastructure, use the self-hosting guide and connect your own model providers.'
	}
]

const faqJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((faq) => ({
		'@type': 'Question',
		name: faq.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: faq.answer
		}
	}))
}
---

<Layout title={SEO.title} description={SEO.description}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

	<section class="border-b border-neutral-200 bg-neutral-50 py-20 dark:border-neutral-800 dark:bg-neutral-950">
		<div class="mx-auto max-w-3xl px-6 text-center">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-500">Pricing</p>
			<h1 class="mt-4 text-4xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-5xl">
				Frontman pricing is simple right now: free during early access.
			</h1>
			<p class="mt-6 text-lg leading-8 text-neutral-600 dark:text-neutral-300">
				Frontman itself is currently free and open source. If you connect your own model
				provider, that provider may still charge for usage. When hosted plans launch, this
				page is where we'll publish them.
			</p>
			<div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
				<a
					href="/docs/api-keys/"
					class="rounded-md bg-primary-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-400"
				>
					Set up a model provider
				</a>
				<a
					href="/docs/reference/self-hosting/"
					class="rounded-md border border-neutral-300 px-6 py-3 text-sm font-semibold text-neutral-900 transition hover:border-primary-400 hover:text-primary-600 dark:border-neutral-700 dark:text-white dark:hover:border-primary-500 dark:hover:text-primary-400"
				>
					Read self-hosting docs
				</a>
			</div>
		</div>
	</section>

	<section class="py-16 sm:py-20">
		<div class="mx-auto grid max-w-5xl gap-6 px-6 lg:grid-cols-[1.3fr_0.7fr]">
			<div class="rounded-3xl border border-neutral-200 bg-white p-8 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-500">
					Current plan
				</p>
				<h2 class="mt-3 text-3xl font-bold text-neutral-950 dark:text-white">Free during early access</h2>
				<p class="mt-4 text-base leading-7 text-neutral-600 dark:text-neutral-300">
					If you want to try Frontman in a real project today, you can. The product is in
					early access, but the core workflow is available now.
				</p>
				<ul class="mt-6 space-y-3 text-sm leading-6 text-neutral-700 dark:text-neutral-200">
					{highlights.map((item) => <li class="flex gap-3"><span class="mt-1 text-primary-500">•</span><span>{item}</span></li>)}
				</ul>
			</div>

			<div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-8 dark:border-neutral-800 dark:bg-neutral-950">
				<h2 class="text-xl font-semibold text-neutral-950 dark:text-white">What can still cost money?</h2>
				<ul class="mt-4 space-y-3 text-sm leading-6 text-neutral-600 dark:text-neutral-300">
					{costs.map((item) => <li class="flex gap-3"><span class="mt-1 text-primary-500">•</span><span>{item}</span></li>)}
				</ul>
				<div class="mt-8 rounded-2xl border border-dashed border-neutral-300 p-4 dark:border-neutral-700">
					<p class="text-sm font-medium text-neutral-950 dark:text-white">Need the setup details?</p>
					<p class="mt-2 text-sm leading-6 text-neutral-600 dark:text-neutral-300">
						Start with <a class="underline underline-offset-4" href="/docs/installation/">installation</a>,
						then configure <a class="underline underline-offset-4" href="/docs/api-keys/">API keys</a> or
						follow the <a class="underline underline-offset-4" href="/docs/reference/self-hosting/">self-hosting guide</a>.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="border-y border-neutral-200 bg-neutral-50 py-16 dark:border-neutral-800 dark:bg-neutral-950">
		<div class="mx-auto max-w-4xl px-6">
			<h2 class="text-3xl font-bold tracking-tight text-neutral-950 dark:text-white">Frequently asked questions</h2>
			<div class="mt-8 space-y-4">
				{faqs.map((faq) => (
					<details class="rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-800 dark:bg-neutral-900">
						<summary class="cursor-pointer list-none text-lg font-semibold text-neutral-950 dark:text-white">
							{faq.question}
						</summary>
						<p class="mt-4 text-base leading-7 text-neutral-600 dark:text-neutral-300">{faq.answer}</p>
					</details>
				))}
			</div>
		</div>
	</section>

	<section class="py-16 sm:py-20">
		<div class="mx-auto max-w-4xl px-6 text-center">
			<h2 class="text-3xl font-bold tracking-tight text-neutral-950 dark:text-white">
				Want to evaluate Frontman before paid plans launch?
			</h2>
			<p class="mt-4 text-base leading-7 text-neutral-600 dark:text-neutral-300">
				Read how the product works, compare it with other AI coding tools, or install it in a
				real app and see the workflow yourself.
			</p>
			<div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
				<a class="rounded-md bg-primary-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-400" href="/how-it-works/">How Frontman works</a>
				<a class="rounded-md border border-neutral-300 px-6 py-3 text-sm font-semibold text-neutral-900 transition hover:border-primary-400 hover:text-primary-600 dark:border-neutral-700 dark:text-white dark:hover:border-primary-500 dark:hover:text-primary-400" href="/compare/">Compare Frontman</a>
			</div>
		</div>
	</section>
</Layout>
