---
// About Page
// ------------
// Description: Meet the founders of Frontman.

// Components
import Layout from '../layouts/Layout.astro'
import { Icon } from 'astro-icon/components'

// Content
const SEO = {
	title: 'About Frontman | Meet the Team',
	description:
		'Frontman is built by Danni Friedland and Itay Adler — two co-founders who believe AI coding tools should see what developers see.'
}

const founders = [
	{
		name: 'Danni Friedland',
		location: 'Berlin, Germany',
		bio: 'Co-founder of Frontman. Previously founded Walnut Inc, a category leader in sales tech. Focused on developer tools and the intersection of AI and frontend engineering.',
		github: 'https://github.com/BlueHotDog',
		linkedin: 'https://www.linkedin.com/in/dannifriedland/',
		twitter: 'https://twitter.com/dannifriedland',
	},
	{
		name: 'Itay Adler',
		location: 'Israel',
		bio: 'Co-founder of Frontman. Background in full-stack engineering and product development. Focused on making AI tools that understand running applications, not just source files.',
		github: 'https://github.com/itayadler',
		linkedin: 'https://www.linkedin.com/in/itay-adler-93a4bb6/',
		twitter: 'https://twitter.com/itayad',
	},
]

// Person schema for each founder
const personSchemas = founders.map((founder) => ({
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: founder.name,
	jobTitle: 'Co-founder',
	worksFor: {
		'@type': 'Organization',
		name: 'Frontman',
		url: 'https://frontman.sh',
	},
	sameAs: [founder.github, founder.linkedin, founder.twitter].filter(Boolean),
}))
---

<Layout title={SEO.title} description={SEO.description}>
	{personSchemas.map((schema) => (
		<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
	))}

	<div class="about-page">
		<div class="about-container">
			<!-- Header -->
			<p class="about-label">About</p>
			<h1 class="about-title">Built by developers,<br />for developers</h1>
			<p class="about-subtitle">
				Frontman is an open-source AI coding agent that lives inside your browser. It sees your live DOM, understands your running application, and edits your actual source code. We built it because every other AI coding tool was blind to the UI.
			</p>

			<!-- Founders -->
			<div class="founders-grid">
				{founders.map((founder) => (
					<div class="founder-card">
						<div class="founder-info">
							<h2 class="founder-name">{founder.name}</h2>
							<p class="founder-role">Co-founder</p>
							<p class="founder-location">{founder.location}</p>
						</div>
						<p class="founder-bio">{founder.bio}</p>
						<div class="founder-links">
							<a href={founder.github} target="_blank" rel="noopener noreferrer" aria-label={`${founder.name} on GitHub`}>
								<Icon name="github-icon" class="link-icon" aria-hidden="true" />
								<span>GitHub</span>
							</a>
							<a href={founder.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${founder.name} on LinkedIn`}>
								<Icon name="linkedin-icon" class="link-icon" aria-hidden="true" />
								<span>LinkedIn</span>
							</a>
							<a href={founder.twitter} target="_blank" rel="noopener noreferrer" aria-label={`${founder.name} on Twitter`}>
								<Icon name="twitter-icon" class="link-icon" aria-hidden="true" />
								<span>Twitter</span>
							</a>
						</div>
					</div>
				))}
			</div>

			<!-- Open Source callout -->
			<div class="oss-section">
				<h2 class="oss-title">Open source from day one</h2>
				<p class="oss-text">
					Frontman is licensed under Apache 2.0. You can read every line of code, every prompt we send to the LLM, and every edit we make to your files. Contributions are welcome.
				</p>
				<a href="https://github.com/frontman-ai/frontman" target="_blank" rel="noopener noreferrer" class="oss-link">
					View on GitHub &rarr;
				</a>
			</div>
		</div>
	</div>
</Layout>

<style>
	.about-page {
		background: #09090b;
		color: #fafafa;
		padding: 80px 24px 120px;
		display: flex;
		justify-content: center;
		min-height: 100vh;
	}

	.about-container {
		max-width: 720px;
		width: 100%;
	}

	/* Header */
	.about-label {
		@apply font-mono;
		font-size: 13px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #71717a;
		margin-bottom: 12px;
	}

	.about-title {
		font-size: 42px;
		font-weight: 700;
		line-height: 1.1;
		margin-bottom: 12px;
		letter-spacing: -0.02em;
		color: #fafafa;
	}

	.about-subtitle {
		font-size: 17px;
		color: #a1a1aa;
		line-height: 1.6;
		margin-bottom: 80px;
		max-width: 580px;
	}

	/* Founders grid */
	.founders-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 32px;
		margin-bottom: 80px;
	}

	@media (min-width: 640px) {
		.founders-grid {
			grid-template-columns: 1fr 1fr;
			gap: 40px;
		}
	}

	.founder-card {
		border: 1px solid #27272a;
		border-radius: 12px;
		padding: 32px;
		transition: border-color 0.2s;
	}

	.founder-card:hover {
		border-color: #3f3f46;
	}

	.founder-info {
		margin-bottom: 20px;
	}

	.founder-name {
		font-size: 22px;
		font-weight: 600;
		color: #fafafa;
		margin-bottom: 4px;
		letter-spacing: -0.01em;
	}

	.founder-role {
		font-size: 14px;
		color: #71717a;
		margin-bottom: 2px;
	}

	.founder-location {
		font-size: 14px;
		color: #52525b;
	}

	.founder-bio {
		font-size: 15px;
		line-height: 1.6;
		color: #a1a1aa;
		margin-bottom: 24px;
	}

	.founder-links {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}

	.founder-links a {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		color: #71717a;
		transition: color 0.2s;
		text-decoration: none;
	}

	.founder-links a:hover {
		color: #fafafa;
	}

	.link-icon {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
	}

	/* Open Source section */
	.oss-section {
		border-top: 1px solid #27272a;
		padding-top: 48px;
	}

	.oss-title {
		font-size: 20px;
		font-weight: 600;
		color: #fafafa;
		margin-bottom: 8px;
		letter-spacing: -0.01em;
	}

	.oss-text {
		font-size: 15px;
		line-height: 1.7;
		color: #a1a1aa;
		max-width: 560px;
		margin-bottom: 16px;
	}

	.oss-link {
		font-size: 15px;
		color: #fafafa;
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.oss-link:hover {
		color: #a1a1aa;
	}

	@media (max-width: 640px) {
		.about-page {
			padding: 48px 20px 80px;
		}

		.about-title {
			font-size: 32px;
		}

		.about-subtitle {
			margin-bottom: 48px;
		}

		.founder-card {
			padding: 24px;
		}
	}
</style>
