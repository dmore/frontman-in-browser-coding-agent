{
	"name": "frontman",
	"namespace": true,
	"dependencies": [
		"@frontman/bindings",
		"@frontman-ai/client",
		"@frontman-ai/astro",
		"@frontman-ai/frontman-client",
		"@frontman-ai/nextjs",
		"@frontman-ai/frontman-protocol",
		"@frontman-ai/react-statestore",
		"@rescript/webapi"
	],
	"package-specs": {
		"module": "esmodule",
		"in-source": true
	},
	"jsx": {
		"version": 4
	},
	"reanalyze": {
		"suppress": [
			"libs/bindings",
			"libs/experimental-rescript-webapi",
			"libs/frontman-protocol"
		]
	},
	"gentypeconfig": {
		"language": "typescript",
		"module": "esmodule",
		"shims": {
			"JsxDOM": "JsxDOM"
		}
	},
	"suffix": ".res.mjs",
	"compiler-flags": []
}
