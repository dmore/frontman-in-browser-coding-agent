#!/usr/bin/env bash
# Create a containerized worktree: git worktree + Podman pod + postgres + dev container.
# Called by: make wt-new
#
# Required env: BRANCH, DEV_IMAGE, MD5CMD
# MD5CMD is the platform-specific md5 pipeline (e.g. "md5sum | cut -c1-4")
#
# Networking: pods use pasta (rootless-friendly) with host-published ports.
# Caddy runs on --network=host and routes to localhost:<port>.
# Port range per worktree is derived from the 4-char hex hash:
#   base = (0xHASH % 5000) + 10000   в†’ range 10000вЂ“14999
#   Phoenix: base+0, Vite: base+1, Next.js: base+2,
#   Storybook: base+3, Marketing: base+4

set -euo pipefail

CYAN='\033[36m'; GREEN='\033[32m'; YELLOW='\033[33m'; RESET='\033[0m'

BRANCH="${BRANCH:?BRANCH is required}"
DEV_IMAGE="${DEV_IMAGE:?DEV_IMAGE is required}"

HASH=$(echo -n "$BRANCH" | eval "$MD5CMD")
POD_NAME="worktree-${HASH}"
WT_DIR="$(pwd)/.worktrees/${BRANCH}"

# Derive deterministic port range from hash
BASE_PORT=$(( 16#${HASH} % 5000 + 10000 ))
PORT_PHOENIX=$((BASE_PORT))
PORT_VITE=$((BASE_PORT + 1))
PORT_NEXTJS=$((BASE_PORT + 2))
PORT_STORYBOOK=$((BASE_PORT + 3))
PORT_MARKETING=$((BASE_PORT + 4))

printf "${CYAN}Creating containerized worktree${RESET}\n"
printf "  Branch:  %s\n" "$BRANCH"
printf "  Hash:    %s\n" "$HASH"
printf "  Pod:     %s\n" "$POD_NAME"
printf "  Ports:   %sвЂ“%s\n" "$PORT_PHOENIX" "$PORT_MARKETING"
echo ""

# в”Ђв”Ђ Preflight в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if ! podman image inspect "$DEV_IMAGE" &>/dev/null; then
  printf "${YELLOW}Error: Dev image not built. Run 'make infra-up' first.${RESET}\n"
  exit 1
fi
if podman pod inspect "$POD_NAME" &>/dev/null; then
  printf "${YELLOW}Pod %s already exists. Use 'make wt-start' to resume.${RESET}\n" "$POD_NAME"
  exit 1
fi

# в”Ђв”Ђ Git worktree в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf "${YELLOW}==> Creating git worktree...${RESET}\n"
mkdir -p .worktrees
if [ -d "$WT_DIR" ]; then
  printf "${GREEN}Worktree already exists at %s${RESET}\n" "$WT_DIR"
elif git show-ref --verify --quiet "refs/heads/${BRANCH}"; then
  git worktree add "$WT_DIR" "$BRANCH"
else
  git worktree add "$WT_DIR" -b "$BRANCH"
fi
mkdir -p "$WT_DIR/.claude/projects" "$WT_DIR/.claude/plans" "$WT_DIR/.claude/todos"
touch "$WT_DIR/.claude/history.jsonl"
echo ""

# в”Ђв”Ђ Secrets в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf "${YELLOW}==> Resolving secrets...${RESET}\n"
if ! op account get &>/dev/null; then
  printf "${YELLOW}Error: 1Password CLI is not signed in. Run 'op signin' first.${RESET}\n"
  exit 1
fi
op run --no-masking --env-file=apps/frontman_server/envs/.dev.secrets.env -- env \
  | grep -v '^_=' | grep -v '^SHLVL=' | grep -v '^PWD=' | grep -v '^OLDPWD=' \
  | grep -E '^(WORKOS_|OPENROUTER_|SENTRY_|SECRET_|DATABASE_|PHX_|FRONTMAN_)' \
  > "$WT_DIR/.env.secrets.resolved"
printf "${GREEN}Secrets resolved.${RESET}\n"
echo ""

# в”Ђв”Ђ Pod + containers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf "${YELLOW}==> Creating Podman pod: %s${RESET}\n" "$POD_NAME"
podman pod create --name "$POD_NAME" \
  -p "${PORT_PHOENIX}:4000" \
  -p "${PORT_VITE}:5173" \
  -p "${PORT_NEXTJS}:3000" \
  -p "${PORT_STORYBOOK}:6006" \
  -p "${PORT_MARKETING}:4321"
echo ""

printf "${YELLOW}==> Starting PostgreSQL...${RESET}\n"
podman run -d \
  --pod "$POD_NAME" \
  --name "${POD_NAME}-pg" \
  -e POSTGRES_USER=postgres \
  -e POSTGRES_PASSWORD=postgres \
  -v "worktree-${HASH}-pgdata:/var/lib/postgresql/data" \
  docker.io/library/postgres:16
echo ""

printf "${YELLOW}==> Starting dev container...${RESET}\n"
podman run -d \
  --pod "$POD_NAME" \
  --name "${POD_NAME}-dev" \
  --user root \
  -e "HOME=/home/vscode" \
  --env-file "$WT_DIR/.env.secrets.resolved" \
  -e "WORKTREE_HASH=${HASH}" \
  -e "WORKTREE_BRANCH=${BRANCH}" \
  -e "WORKTREE_PORT_PHOENIX=${PORT_PHOENIX}" \
  -e "WORKTREE_PORT_VITE=${PORT_VITE}" \
  -e "WORKTREE_PORT_NEXTJS=${PORT_NEXTJS}" \
  -e "WORKTREE_PORT_STORYBOOK=${PORT_STORYBOOK}" \
  -e "WORKTREE_PORT_MARKETING=${PORT_MARKETING}" \
  -v "${WT_DIR}:/workspaces/frontman" \
  -v "worktree-${HASH}-node-modules:/workspaces/frontman/node_modules" \
  -v "worktree-${HASH}-mix-build:/workspaces/frontman/apps/frontman_server/_build" \
  -v "worktree-${HASH}-mix-deps:/workspaces/frontman/apps/frontman_server/deps" \
  "$DEV_IMAGE" \
  sleep infinity
echo ""

# в”Ђв”Ђ Wait for postgres в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf "${YELLOW}==> Waiting for PostgreSQL to be ready...${RESET}\n"
for _ in $(seq 1 30); do
  if podman exec "${POD_NAME}-dev" bash -c 'pg_isready -h localhost -U postgres' &>/dev/null; then
    break
  fi
  sleep 1
done
echo ""

# в”Ђв”Ђ Setup в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf "${YELLOW}==> Running setup inside container...${RESET}\n"
podman exec \
  -e "WORKTREE_HASH=${HASH}" \
  -e "WORKTREE_BRANCH=${BRANCH}" \
  -w /workspaces/frontman \
  "${POD_NAME}-dev" \
  bash ./infra/local/worktree-setup.sh
echo ""

# в”Ђв”Ђ Caddy в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf "${YELLOW}==> Updating Caddy routes...${RESET}\n"
bash ./infra/local/caddy-regen.sh
echo ""

# в”Ђв”Ђ Done в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf "${GREEN}==> Containerized worktree ready!${RESET}\n"
echo ""
echo "Start development:"
echo "  make wt-dev BRANCH=${BRANCH}"
echo ""
echo "URLs (via Caddy):"
echo "  Phoenix:   https://${HASH}.api.frontman.local"
echo "  Vite:      https://${HASH}.vite.frontman.local"
echo "  Next.js:   https://${HASH}.nextjs.frontman.local/frontman"
echo "  Storybook: https://${HASH}.storybook.frontman.local"
echo "  Marketing: https://${HASH}.marketing.frontman.local"
echo ""
echo "Direct ports (localhost):"
echo "  Phoenix:   localhost:${PORT_PHOENIX}"
echo "  Vite:      localhost:${PORT_VITE}"
echo "  Next.js:   localhost:${PORT_NEXTJS}"
echo "  Storybook: localhost:${PORT_STORYBOOK}"
echo "  Marketing: localhost:${PORT_MARKETING}"
